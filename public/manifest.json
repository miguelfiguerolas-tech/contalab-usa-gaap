{
    "manifest_version": 3,
    "name": "ContaLab - Contabilidad para Estudiantes",
    "version": "1.1.0",
    "description": "Gestión contable completa: Diario, Mayor y Balances. Diseñado para estudiantes.",
    "action": {
        "default_title": "Abrir ContaLab"
    },
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
        "storage",
        "unlimitedStorage"
    ]
}